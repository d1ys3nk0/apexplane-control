PG_IMAGE="{{ app_stack_pg_image }}"

PG_BASE="{{ pg_base }}"
PG_USER="{{ pg_user }}"
PG_PASS="{{ pg_pass }}"
PG_HOST="{{ pg_host }}"
PG_PORT="{{ pg_port }}"
PG_SSL="{{ pg_sslmode | default(app_stack_pg_sslmode, true) }}"

{% if app_stack_cluster_realm == 'prd' and app_stack_backups_secret | string | length > 0 %}
PG_DUMP_SECRET="{{ app_stack_backups_secret }}"
{% endif %}
{% if app_stack_backups_s3_enabled | bool %}
PG_DUMP_S3_BUCKET="{{ app_stack_backups_s3_bucket }}"
PG_DUMP_S3_ENDPOINT="{{ app_stack_backups_s3_endpoint }}"
PG_DUMP_S3_PREFIX="postgres/{{ pg_base }}/$(date -u '+%y/%V')"
PG_DUMP_S3_REGION="{{ app_stack_backups_s3_region }}"
PG_DUMP_S3_ACCESS_KEY="{{ app_stack_backups_s3_access_key }}"
PG_DUMP_S3_SECRET_KEY="{{ app_stack_backups_s3_secret_key }}"
{% endif %}

PG_RESTORE_CONCURRENCY="{{ app_stack_pg_restore_concurrency }}"
{% if app_stack_pg_restore_no_prepare | bool %}
PG_RESTORE_NO_PREPARE="true"
{% endif %}
{% if app_stack_pg_restore_no_recreate | bool %}
PG_RESTORE_NO_RECREATE="true"
{% endif %}
{% if app_stack_cluster_realm == 'prd' %}
PG_RESTORE_EXCLUDE_EXTENSIONS="pg_stat_statements"
{% endif %}
{% if app_stack_cluster_realm == 'prd' and app_stack_backups_secret | string | length > 0 %}
PG_RESTORE_SECRET="{{ app_stack_backups_secret }}"
{% endif %}
{% if app_stack_backups_s3_enabled | bool %}
PG_RESTORE_S3_BUCKET="{{ app_stack_backups_s3_bucket }}"
PG_RESTORE_S3_ENDPOINT="{{ app_stack_backups_s3_endpoint }}"
PG_RESTORE_S3_PREFIX="postgres/{{ pg_base }}"
PG_RESTORE_S3_REGION="{{ app_stack_backups_s3_region }}"
PG_RESTORE_S3_ACCESS_KEY="{{ app_stack_backups_s3_access_key }}"
PG_RESTORE_S3_SECRET_KEY="{{ app_stack_backups_s3_secret_key }}"
{% endif %}
