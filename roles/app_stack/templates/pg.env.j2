PG_IMAGE="{{ app_stack_pg_image }}"

PG_BASE="{{ pg_base }}"
PG_USER="{{ pg_user }}"
PG_PASS="{{ pg_pass }}"
PG_HOST="{{ pg_host }}"
PG_PORT="{{ pg_port }}"
PG_SSL="{{ pg_sslmode | default(app_stack_pg_sslmode, true) }}"

{% if app_stack_pg_backup_concurrency | int != 1 %}
PG_BACKUP_CONCURRENCY="{{ app_stack_pg_backup_concurrency }}"
{% endif %}
{% if app_stack_cluster_realm == 'prd' and app_stack_pg_backup_secret | string | length > 0 %}
PG_BACKUP_SECRET="{{ app_stack_pg_backup_secret }}"
{% endif %}
{% if app_stack_pg_backup_s3_enabled | bool %}
PG_BACKUP_S3_ENDPOINT="{{ app_stack_pg_backup_s3_endpoint }}"
PG_BACKUP_S3_REGION="{{ app_stack_pg_backup_s3_region }}"
PG_BACKUP_S3_BUCKET="{{ app_stack_pg_backup_s3_bucket }}"
PG_BACKUP_S3_PREFIX="postgres/{{ pg_base }}/$(date -u '+%y/%V')"
PG_BACKUP_S3_ACCESS_KEY="{{ app_stack_pg_backup_s3_access_key }}"
PG_BACKUP_S3_SECRET_KEY="{{ app_stack_pg_backup_s3_secret_key }}"
{% endif %}

{% if app_stack_pg_recover_concurrency | int != 1 %}
PG_RECOVER_CONCURRENCY="{{ app_stack_pg_recover_concurrency }}"
{% endif %}
{% if app_stack_pg_recover_no_prepare | bool %}
PG_RECOVER_NO_PREPARE="true"
{% endif %}
{% if app_stack_pg_recover_no_recreate | bool %}
PG_RECOVER_NO_RECREATE="true"
{% endif %}
{% if app_stack_cluster_realm == 'prd' %}
PG_RECOVER_EXCLUDE_EXTENSIONS="pg_stat_statements"
{% endif %}
{% if app_stack_cluster_realm == 'prd' and app_stack_pg_recover_secret | string | length > 0 %}
PG_RECOVER_SECRET="{{ app_stack_pg_recover_secret }}"
{% endif %}
{% if app_stack_pg_recover_s3_enabled | bool %}
PG_RECOVER_S3_ENDPOINT="{{ app_stack_pg_recover_s3_endpoint }}"
PG_RECOVER_S3_REGION="{{ app_stack_pg_recover_s3_region }}"
PG_RECOVER_S3_BUCKET="{{ app_stack_pg_recover_s3_bucket }}"
PG_RECOVER_S3_PREFIX="{{ app_stack_pg_recover_s3_prefix_template | replace('{pg_base}', pg_base) | replace('{pg_base_suffix}', pg_base_suffix | default(pg_base, true)) }}"
PG_RECOVER_S3_ACCESS_KEY="{{ app_stack_pg_recover_s3_access_key }}"
PG_RECOVER_S3_SECRET_KEY="{{ app_stack_pg_recover_s3_secret_key }}"
{% endif %}
