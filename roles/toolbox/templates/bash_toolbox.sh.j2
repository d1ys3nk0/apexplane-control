dc-env() {
  sudo docker inspect "$1" --format '{{range .Config.Env}}{{println .}}{{end}}'
}

dc-volumes() {
  sudo docker inspect "$1" --format '{{range .Mounts}}{{printf "%s name=%s source=%s destination=%s\n" .Type .Name .Source .Destination}}{{end}}'
}

docker-secret-read() {
  local completed=0
  local image
  local secret_name
  local service_name
  local state
  local status
  local wait_attempt

  if [ "$#" -ne 1 ]; then
    printf 'usage: docker-secret-read <secret-name>\n' >&2
    return 2
  fi

  secret_name=$1
  image=${DOCKER_SECRET_READ_IMAGE:-alpine:3.20}
  service_name="toolbox-secret-read-$(date +%s)-$$"

  sudo docker secret inspect "$secret_name" >/dev/null || return

  sudo docker service create \
    --detach=true \
    --name "$service_name" \
    --restart-condition none \
    --secret "source=$secret_name,target=secret,mode=0400" \
    "$image" \
    cat /run/secrets/secret >/dev/null || return

  for wait_attempt in {1..60}; do
    state=$(sudo docker service ps --no-trunc --format '{{.CurrentState}}' "$service_name" | head -n 1)
    case "$state" in
      Complete*)
        completed=1
        break
        ;;
      Failed*|Rejected*)
        sudo docker service logs --raw "$service_name" 2>/dev/null
        sudo docker service rm "$service_name" >/dev/null
        return 1
        ;;
    esac
    sleep 1
  done

  if [ "$completed" -ne 1 ]; then
    printf 'docker-secret-read: service did not complete within 60 seconds: %s\n' "${state:-unknown}" >&2
    sudo docker service logs --raw "$service_name" 2>/dev/null
    sudo docker service rm "$service_name" >/dev/null
    return 1
  fi

  sudo docker service logs --raw "$service_name"
  status=$?
  sudo docker service rm "$service_name" >/dev/null
  return "$status"
}
{% endraw %}
