Port {{ base_hardening_ssh_port }}
PermitRootLogin no
PasswordAuthentication no
KbdInteractiveAuthentication no
ChallengeResponseAuthentication no
PubkeyAuthentication yes
PermitEmptyPasswords no
MaxAuthTries 3
LoginGraceTime 30
X11Forwarding no
{% if base_hardening_ssh_users | length > 0 %}
AllowUsers {{ base_hardening_ssh_users | join(' ') }}
{% endif %}
