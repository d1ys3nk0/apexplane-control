concurrent = {{ docker_gitlab_runner_concurrency | int }}
check_interval = {{ docker_gitlab_runner_check_interval | int }}
shutdown_timeout = {{ docker_gitlab_runner_shutdown_timeout | int }}

[session_server]
  session_timeout = {{ docker_gitlab_runner_session_timeout | int }}

[[runners]]
  name = {{ docker_gitlab_runner_name | to_json }}
  url = {{ docker_gitlab_runner_url | to_json }}
  token = {{ docker_gitlab_runner_token | to_json }}
  executor = {{ docker_gitlab_runner_executor | to_json }}
  [runners.cache]
    MaxUploadedArchiveSize = 0
  [runners.docker]
    tls_verify = {{ docker_gitlab_runner_docker_tls_verify | bool | ternary('true', 'false') }}
    image = {{ docker_gitlab_runner_docker_image_full | to_json }}
    privileged = {{ docker_gitlab_runner_docker_privileged | bool | ternary('true', 'false') }}
    disable_entrypoint_overwrite = {{ docker_gitlab_runner_docker_disable_entrypoint_overwrite | bool | ternary('true', 'false') }}
    oom_kill_disable = {{ docker_gitlab_runner_docker_oom_kill_disable | bool | ternary('true', 'false') }}
    disable_cache = {{ docker_gitlab_runner_docker_disable_cache | bool | ternary('true', 'false') }}
    volumes = {{ docker_gitlab_runner_docker_volumes | to_json }}
    shm_size = {{ docker_gitlab_runner_docker_shm_size | int }}
    network_mtu = {{ docker_gitlab_runner_docker_network_mtu | int }}
    extra_hosts = {{ docker_gitlab_runner_docker_extra_hosts | to_json }}
    pull_policy = {{ docker_gitlab_runner_docker_pull_policy | to_json }}
    allowed_pull_policies = {{ docker_gitlab_runner_docker_allowed_pull_policies | to_json }}
    service_memory_reservation = {{ docker_gitlab_runner_service_mem_res | to_json }}
    service_memory = {{ docker_gitlab_runner_service_mem_lim | to_json }}
    service_memory_swap = {{ docker_gitlab_runner_service_mem_swp | to_json }}
