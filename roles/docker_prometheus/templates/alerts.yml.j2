---

{% raw %}
groups:
  - name: common
    rules:
      - alert: MissingResponse
        expr: up == 0
        for: 1m
        labels:
          sev: critical
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: '{{ $labels.instance }}/{{ $labels.job }} is not reachable'
          description: up == {{ $value }}

  - name: node
    rules:
      - alert: HostSystemdServiceCrashed
        expr: node_systemd_unit_state{state='failed'} == 1
        for: 0m
        labels:
          sev: critical
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: SystemD service crashed on {{ $labels.instance }}
          description: Detected a failed SystemD service with value {{ $value }}.

      - alert: HostOomKillDetected
        expr: increase(node_vmstat_oom_kill[1m]) > 0
        for: 0m
        labels:
          sev: critical
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: OOM kill detected on {{ $labels.instance }}
          description: Detected an out-of-memory kill event with value {{ $value }}.

      - alert: HostOutOfDiskSpace
        expr: node_filesystem_avail_bytes{mountpoint='/'} / node_filesystem_size_bytes{mountpoint='/'} * 100 < 10
        for: 1m
        labels:
          sev: critical
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: Disk space critically low on {{ $labels.instance }}
          description: Available disk space is below 10% (currently {{ $value }}%).

      - alert: HostOutOfInodes
        expr: node_filesystem_files_free{mountpoint ='/'} / node_filesystem_files{mountpoint='/'} * 100 < 10
        for: 1m
        labels:
          sev: critical
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: Inode shortage on {{ $labels.instance }}
          description: 'Available inodes are below 10% (current value: {{ $value }}%).'

      - alert: HostSwapIsFillingUp
        expr: (1 - (node_memory_SwapFree_bytes / node_memory_SwapTotal_bytes)) * 100 > 70
        for: 1m
        labels:
          sev: critical
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: Swap usage high on {{ $labels.instance }}
          description: 'Swap utilization exceeds 70% (current: {{ $value }}%).'

      - alert: HostOutOfMemory
        expr: node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes * 100 < 10
        for: 1m
        labels:
          sev: critical
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: Out of memory on {{ $labels.instance }}
          description: Available memory is below 10% (currently {{ $value }}%).

      - alert: HostMemoryUnderMemoryPressure
        expr: rate(node_vmstat_pgmajfault[1m]) > 1000
        for: 1m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: High memory pressure on {{ $labels.instance }}
          description: Major page fault rate exceeds threshold (>1000 faults/min) with value {{ $value }}.

      - alert: HostHighCpuLoad
        expr: 100 - (avg by(instance) (rate(node_cpu_seconds_total{mode='idle'}[2m])) * 100) > 90
        for: 1m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: High CPU load on {{ $labels.instance }}
          description: 'CPU load exceeds 90% (current load: {{ $value }}%).'

      - alert: HostCpuStealNoisyNeighbor
        expr: avg by(instance) (rate(node_cpu_seconds_total{mode='steal'}[5m])) * 100 > 10
        for: 1m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: High CPU steal on {{ $labels.instance }}
          description: 'CPU steal exceeds 10%, suggesting resource contention (current: {{ $value }}%).'

      - alert: HostConntrackLimit
        expr: node_nf_conntrack_entries / node_nf_conntrack_entries_limit > 0.8
        for: 1m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: High conntrack usage on {{ $labels.instance }}
          description: 'Conntrack entries exceed 80% of the limit (current: {{ $value }}).'

      - alert: HostNetworkInterfaceSaturated
        expr: (rate(node_network_receive_bytes_total{device!~'^tap.*'}[1m]) + rate(node_network_transmit_bytes_total{device!~'^tap.*'}[1m])) / node_network_speed_bytes{device!~'^tap.*'} > 0.8
        for: 1m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: Network interface saturated on {{ $labels.instance }}:{{ $labels.interface }}
          description: 'Combined network throughput exceeds 80% of capacity (current: {{ $value }}).'

      - alert: HostUnusualNetworkThroughputIn
        expr: sum by (instance) (rate(node_network_receive_bytes_total[2m])) / 1024 / 1024 > 100
        for: 5m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: High inbound network throughput on {{ $labels.instance }}
          description: 'Inbound network rate exceeds 100 MB/s (current: {{ $value }} MB/s).'

      - alert: HostUnusualNetworkThroughputOut
        expr: sum by (instance) (rate(node_network_transmit_bytes_total[2m])) / 1024 / 1024 > 100
        for: 5m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: High outbound network throughput on {{ $labels.instance }}
          description: 'Outbound network rate exceeds 100 MB/s (current: {{ $value }} MB/s).'

      - alert: HostUnusualDiskReadRate
        expr: sum by (instance) (rate(node_disk_read_bytes_total[2m])) / 1024 / 1024 > 50
        for: 5m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: High disk read rate on {{ $labels.instance }}
          description: 'Disk read throughput exceeds 50 MB/s (current: {{ $value }} MB/s).'

      - alert: HostUnusualDiskWriteRate
        expr: sum by (instance) (rate(node_disk_written_bytes_total[2m])) / 1024 / 1024 > 50
        for: 5m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: High disk write rate on {{ $labels.instance }}
          description: 'Disk write throughput exceeds 50 MB/s (current: {{ $value }} MB/s).'

      - alert: HostUnusualDiskReadLatency
        expr: rate(node_disk_read_time_seconds_total[1m]) / rate(node_disk_reads_completed_total[1m]) > 0.1 and rate(node_disk_reads_completed_total[1m]) > 0
        for: 5m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: High disk read latency on {{ $labels.instance }}
          description: 'Average disk read latency exceeds 0.1 seconds (current: {{ $value }} s).'

      - alert: HostUnusualDiskWriteLatency
        expr: rate(node_disk_write_time_seconds_totali{device!~'mmcblk.+'}[1m]) / rate(node_disk_writes_completed_total{device!~'mmcblk.+'}[1m]) > 0.1 and rate(node_disk_writes_completed_total{device!~'mmcblk.+'}[1m]) > 0
        for: 5m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: High disk write latency on {{ $labels.instance }}
          description: 'Average disk write latency exceeds 0.1 seconds (current: {{ $value }} s).'

      - alert: HostContextSwitching
        expr: (rate(node_context_switches_total[5m])) / (count without(cpu, mode) (node_cpu_seconds_total{mode='idle'})) > 5000
        for: 5m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: High context switching on {{ $labels.instance }}
          description: 'Context switch rate exceeds 5000 (current: {{ $value }}).'

      - alert: HostClockSkew
        expr: (node_timex_offset_seconds > 0.05 and deriv(node_timex_offset_seconds[5m]) >= 0) or (node_timex_offset_seconds < -0.05 and deriv(node_timex_offset_seconds[5m]) <= 0)
        for: 5m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: Clock skew detected on {{ $labels.instance }}
          description: 'Clock offset is abnormal (current offset: {{ $value }} seconds).'

      - alert: HostClockNotSynchronising
        expr: min_over_time(node_timex_sync_status[1m]) == 0 and node_timex_maxerror_seconds >= 16
        for: 5m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: Clock synchronization failure on {{ $labels.instance }}
          description: 'Clock is not synchronizing properly (max error: {{ $value }} seconds).'

      - alert: HostKernelVersionDeviations
        expr: count(sum(label_replace(node_uname_info, 'kernel', '$1', 'release', '([0-9]+.[0-9]+.[0-9]+).*')) by (kernel)) > 1
        for: 24h
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: Kernel version deviation on {{ $labels.instance }}
          description: 'Multiple kernel versions detected on the host (count: {{ $value }}).'

  - name: docker
    rules:
      - alert: ContainerHighRestartCount
        expr: changes(container_start_time_seconds{name!=''}[5m]) > 2
        for: 0m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: High container restart count on {{ $labels.instance }}
          description: 'Container {{ $labels.name }} restarted more than 2 times in 5 minutes (restarts: {{ $value }}).'

      - alert: ContainerMemoryUsage
        expr: (sum(container_memory_working_set_bytes{name!=''}) BY (instance, name) / sum(container_spec_memory_limit_bytes{name!='', container_spec_memory_limit_bytes!='0'}) BY (instance, name) * 100) > 90
        for: 5m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: High memory usage in container on {{ $labels.instance }}
          description: 'Container {{ $labels.name }} memory usage exceeds 90% (current: {{ $value }}%).'

      - alert: ContainerCpuUsage
        expr: (sum(rate(container_cpu_usage_seconds_total{name!=''}[3m])) BY (instance, name) * 100) > 90
        for: 5m
        labels:
          sev: warning
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: High CPU usage in container on {{ $labels.instance }}
          description: 'Container {{ $labels.name }} CPU usage exceeds 90% (current: {{ $value }}%).'

      - alert: ContainerUnhealthy
        expr: container_health_status{name!=''} == 0
        for: 0m
        labels:
          sev: critical
          cluster: '{{ $labels.cluster }}'
          realm: '{{ $labels.realm }}'
          platform: '{{ $labels.platform }}'
        annotations:
          summary: Unhealthy container on {{ $labels.instance }}
          description: 'Container {{ $labels.name }} is reporting an unhealthy status (value: {{ $value }}).'
{% endraw %}
{% if docker_prometheus_custom_alerts | trim | length > 0 %}

{{ docker_prometheus_custom_alerts | trim | indent(2, true) }}
{% endif %}
