PG_IMAGE="{{ pg_image }}"

PG_BASE="{{ pg_base }}"
PG_USER="{{ pg_user }}"
PG_PASS="{{ pg_pass }}"
PG_HOST="{{ pg_host }}"
PG_PORT="{{ pg_port }}"
PG_SSL="{{ pg_ssl }}"

{% if backups_postgres_backup_concurrency | string | length > 0 %}
PG_BACKUP_CONCURRENCY="{{ backups_postgres_backup_concurrency }}"
{% endif %}
{% if backups_postgres_backup_secret | string | length > 0 %}
PG_BACKUP_SECRET="{{ backups_postgres_backup_secret }}"
{% endif %}
{% if backups_postgres_backup_s3_enabled | bool %}
PG_BACKUP_S3_ACCESS_KEY="{{ backups_postgres_backup_s3_access_key }}"
PG_BACKUP_S3_SECRET_KEY="{{ backups_postgres_backup_s3_secret_key }}"
PG_BACKUP_S3_ENDPOINT="{{ backups_postgres_backup_s3_endpoint }}"
PG_BACKUP_S3_REGION="{{ backups_postgres_backup_s3_region }}"
PG_BACKUP_S3_BUCKET="{{ backups_postgres_backup_s3_bucket }}"
PG_BACKUP_S3_PREFIX="postgres/{{ pg_base }}/$(date -u '+%y/%V')"
{% endif %}

{% if backups_postgres_recover_concurrency | string | length > 0 %}
PG_RECOVER_CONCURRENCY="{{ backups_postgres_recover_concurrency }}"
{% endif %}
{% if backups_postgres_recover_secret | string | length > 0 %}
PG_RECOVER_SECRET="{{ backups_postgres_recover_secret }}"
{% endif %}
{% if backups_postgres_recover_no_prepare | bool %}
PG_RECOVER_NO_PREPARE="true"
{% endif %}
{% if backups_postgres_recover_no_recreate | bool %}
PG_RECOVER_NO_RECREATE="true"
{% endif %}
{% if backups_postgres_recover_exclude_extensions | string | length > 0 %}
PG_RECOVER_EXCLUDE_EXTENSIONS="{{ backups_postgres_recover_exclude_extensions }}"
{% endif %}
{% if backups_postgres_recover_s3_enabled | bool %}
PG_RECOVER_S3_ACCESS_KEY="{{ backups_postgres_recover_s3_access_key }}"
PG_RECOVER_S3_SECRET_KEY="{{ backups_postgres_recover_s3_secret_key }}"
PG_RECOVER_S3_ENDPOINT="{{ backups_postgres_recover_s3_endpoint }}"
PG_RECOVER_S3_REGION="{{ backups_postgres_recover_s3_region }}"
PG_RECOVER_S3_BUCKET="{{ backups_postgres_recover_s3_bucket }}"
PG_RECOVER_S3_PREFIX="postgres/{{ pg_base }}/$(date -u '+%y/%V')"
{% endif %}
