PG_IMAGE="{{ docker_swarm_zitadel_pg_image }}"

PG_BASE="{{ docker_swarm_zitadel_pg_base }}"
PG_USER="{{ docker_swarm_zitadel_pg_user }}"
PG_PASS="{{ docker_swarm_zitadel_pg_pass }}"
PG_HOST="{{ docker_swarm_zitadel_pg_host }}"
PG_PORT="{{ docker_swarm_zitadel_pg_port }}"
PG_SSL="{{ docker_swarm_zitadel_pg_ssl }}"

{% if docker_swarm_zitadel_pg_backup_concurrency | int != 1 %}
PG_BACKUP_CONCURRENCY="{{ docker_swarm_zitadel_pg_backup_concurrency }}"
{% endif %}
{% if docker_swarm_zitadel_pg_backup_secret | string | length > 0 %}
PG_BACKUP_SECRET="{{ docker_swarm_zitadel_pg_backup_secret }}"
{% endif %}
{% if docker_swarm_zitadel_pg_backup_s3_enabled | bool %}
PG_BACKUP_S3_ACCESS_KEY="{{ docker_swarm_zitadel_pg_backup_s3_access_key }}"
PG_BACKUP_S3_SECRET_KEY="{{ docker_swarm_zitadel_pg_backup_s3_secret_key }}"
PG_BACKUP_S3_ENDPOINT="{{ docker_swarm_zitadel_pg_backup_s3_endpoint }}"
PG_BACKUP_S3_REGION="{{ docker_swarm_zitadel_pg_backup_s3_region }}"
PG_BACKUP_S3_BUCKET="{{ docker_swarm_zitadel_pg_backup_s3_bucket }}"
PG_BACKUP_S3_PREFIX="postgres/{{ docker_swarm_zitadel_pg_base }}/$(date -u '+%y/%V')"
{% endif %}

{% if docker_swarm_zitadel_pg_recover_concurrency | string | length > 0 %}
PG_RECOVER_CONCURRENCY="{{ docker_swarm_zitadel_pg_recover_concurrency }}"
{% endif %}
{% if docker_swarm_zitadel_pg_recover_secret | string | length > 0 %}
PG_RECOVER_SECRET="{{ docker_swarm_zitadel_pg_recover_secret }}"
{% endif %}
{% if docker_swarm_zitadel_pg_recover_no_prepare | bool %}
PG_RECOVER_NO_PREPARE="true"
{% endif %}
{% if docker_swarm_zitadel_pg_recover_no_recreate | bool %}
PG_RECOVER_NO_RECREATE="true"
{% endif %}
{% if docker_swarm_zitadel_pg_recover_exclude_extensions | string | length > 0 %}
PG_RECOVER_EXCLUDE_EXTENSIONS="{{ docker_swarm_zitadel_pg_recover_exclude_extensions }}"
{% endif %}
{% if docker_swarm_zitadel_pg_recover_s3_enabled | bool %}
PG_RECOVER_S3_ACCESS_KEY="{{ docker_swarm_zitadel_pg_recover_s3_access_key }}"
PG_RECOVER_S3_SECRET_KEY="{{ docker_swarm_zitadel_pg_recover_s3_secret_key }}"
PG_RECOVER_S3_ENDPOINT="{{ docker_swarm_zitadel_pg_recover_s3_endpoint }}"
PG_RECOVER_S3_REGION="{{ docker_swarm_zitadel_pg_recover_s3_region }}"
PG_RECOVER_S3_BUCKET="{{ docker_swarm_zitadel_pg_recover_s3_bucket }}"
PG_RECOVER_S3_PREFIX="postgres/{{ docker_swarm_zitadel_pg_base }}/$(date -u '+%y/%V')"
{% endif %}
