server:
  http_listen_address: {{ promtail_http_listen_address }}
  http_listen_port: {{ promtail_http_listen_port }}
  grpc_listen_address: {{ promtail_grpc_listen_address }}
  grpc_listen_port: {{ promtail_grpc_listen_port }}

positions:
  filename: {{ promtail_positions_path }}

clients:
  - url: http://{{ promtail_loki_host }}:{{ promtail_loki_port }}/loki/api/v1/push
    timeout: 5s
    backoff_config:
      min_period: 1s
      max_period: 5m
      max_retries: 10

limits_config:
  readline_rate: 10000
  readline_burst: 10000
  readline_rate_drop: false
  max_streams: 0
  max_line_size: 4kb
  max_line_size_truncate: true

scrape_configs:
  - job_name: files
    static_configs:
      - targets: ['localhost']
        labels:
          job: messages
          nodename: '{{ ansible_nodename }}'
          __path__: /var/log/messages
{% if promtail_scrape_certbot_enabled | bool %}
      - targets: ['localhost']
        labels:
          job: certbot
          nodename: '{{ ansible_nodename }}'
          __path__: /var/log/certbot.log
{% endif %}

  - job_name: docker
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
        refresh_interval: 5s
    relabel_configs:
      - source_labels: [__meta_docker_container_log_stream]
        target_label: stream
      # - source_labels: [__meta_docker_container_label_com_docker_swarm_service_name]
      #   target_label: service
      # - source_labels: [__meta_docker_container_label_com_docker_compose_service]
      #   target_label: service
      - source_labels: [__meta_docker_container_name]
        regex: '/([^./]+)\.[^.]+\..*'
        target_label: service
      - source_labels: [__meta_docker_container_name]
        regex: '/([^./]+).*'
        target_label: container
      # - action: replace
      #   source_labels: [service, container]
      #   regex: '^$;(.*)'
      #   replacement: '${2}'
      #   target_label: service
      - replacement: '{{ ansible_nodename }}'
        target_label: nodename
      - action: labeldrop
        regex: '^(service_name|detected_level|hostname|container_id|container_name|container_hash|pod_uid|image|image_id|commit|trace_id|span_id|time|timestamp)$'
    pipeline_stages:
      - docker: {}
      - multiline:
          firstline: '^\[\w+\]|^\<\d+\>'
          max_wait_time: 3s
      - regex:
          expression: '^\[(?P<level>\w+)\].+'
      - labels:
          level:
      - labeldrop: [service_name, detected_level]
