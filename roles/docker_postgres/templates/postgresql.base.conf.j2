listen_addresses = '*'
port = {{ docker_postgres_port }}
hba_file = '/var/lib/postgresql/pg_hba.conf'
shared_preload_libraries = 'pg_stat_statements'
pg_stat_statements.track = ALL
pg_stat_statements.max = 10000
track_activity_query_size = 2048

# Logging
log_connections = on
log_disconnections = off
log_statement = 'ddl'
log_line_prefix = 't=%m pid=%p user=%u db=%d src=%r app=%a '
log_min_duration_statement = 3s

# Timeouts
statement_timeout = 10s
idle_in_transaction_session_timeout = 30s
idle_session_timeout = 24h

# Tuning for {{ docker_postgres_mem_lim[:-1] | int }}MB RAM
max_connections = {{ docker_postgres_connections }}
shared_buffers = {{ ((docker_postgres_mem_lim[:-1] | int) * 0.25) | int }}MB
effective_cache_size = {{ ((docker_postgres_mem_lim[:-1] | int) * 0.8) | int }}MB
maintenance_work_mem = {{ ((docker_postgres_mem_lim[:-1] | int) * 0.0625) | int }}MB
checkpoint_completion_target = 0.9
wal_buffers = {{ [16, ((docker_postgres_mem_lim[:-1] | int) / 128) | int] | min }}MB
default_statistics_target = 100
random_page_cost = 1.1
effective_io_concurrency = 200
work_mem = {{ [16, ((docker_postgres_mem_lim[:-1] | int) * 1024 / 8 / docker_postgres_connections) | int] | max }}kB
huge_pages = off
min_wal_size = {{ docker_postgres_min_wal_size }}
max_wal_size = {{ docker_postgres_max_wal_size }}
max_worker_processes = {{ ansible_processor_vcpus }}
max_parallel_workers_per_gather = {{ [4, (ansible_processor_vcpus / 2) | int] | min }}
max_parallel_workers = {{ ansible_processor_vcpus }}
max_parallel_maintenance_workers = {{ [4, (ansible_processor_vcpus / 2) | int] | min }}

# Replication
wal_level = replica
wal_keep_size = 1GB
max_wal_senders = 10
max_replication_slots = 10
