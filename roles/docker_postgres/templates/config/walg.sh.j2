#!/bin/sh

export PGHOST="/var/run/postgresql"
export PGUSER="admin"
export AWS_ENDPOINT="{{ docker_postgres_backup_s3_endpoint }}"
export AWS_REGION="{{ docker_postgres_backup_s3_region }}"
export AWS_ACCESS_KEY_ID="{{ docker_postgres_backup_s3_access_key }}"
export AWS_SECRET_ACCESS_KEY="{{ docker_postgres_backup_s3_secret_key }}"
export WALG_S3_PREFIX="{{ docker_postgres_backup_s3_prefix }}"
export WALG_DELTA_ORIGIN="LATEST"
export WALG_DELTA_MAX_STEPS="24"
export WALG_COMPRESSION_METHOD="brotli"
export WALG_COMPRESSION_LEVEL="5"
export WALG_DISK_RATE_LIMIT="10485760"
export WALG_UPLOAD_DISK_CONCURRENCY="1"

exec /usr/local/bin/wal-g "$@"
