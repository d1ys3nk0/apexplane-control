pg_run() {
    if [ "$#" -ne 3 ]; then
        echo "usage: pg_run <env-name> <backup|recover> <script>" >&2
        return 64
    fi

    local pg_env_name="$1"
    local pg_action="$2"
    local pg_script="$3"
    local pg_status

    sudo /opt/toolbox/bin/dotenv "$HOME/postgres/${pg_env_name}.env" "$pg_script" 2>&1 | tee "$HOME/postgres/${pg_env_name}.${pg_action}.log"
    pg_status="${PIPESTATUS[0]}"
    return "$pg_status"
}

pg_backup_all() {
    if [ "$#" -ne 0 ]; then
        echo "usage: pg_backup_all" >&2
        return 64
    fi

{% for item in runtime_pg_base_items if item.app == runtime_backup_app.name and item.backup | default(true, true) | bool %}
    pg_run "{{ item.base }}" backup /opt/toolbox/bin/pg_backup || return
{% endfor %}
}

pg_recover_all() {
    if [ "$#" -ne 0 ]; then
        echo "usage: pg_recover_all" >&2
        return 64
    fi

{% for item in runtime_pg_base_items if item.app == runtime_backup_app.name and item.backup | default(true, true) | bool %}
    pg_run "{{ item.base }}" recover /opt/toolbox/bin/pg_recover || return
{% endfor %}
}
