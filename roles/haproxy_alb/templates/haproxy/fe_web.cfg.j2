{#- Build a route match from its host ACL and optional path prefixes. -#}
{%- macro route_match(route, prefixes=none) -%}
{%- set route_domains = [route.domain] if route.domain is string else route.domain -%}
{%- set route_prefixes = prefixes if prefixes is not none else ([] if route.prefix is not defined or route.prefix is none or (route.prefix is string and route.prefix | trim | length == 0) else ([route.prefix | string | trim] if route.prefix is string else (route.prefix | map('string') | map('trim') | list))) -%}
{%- if route.target_port is defined -%}
host_{{ route.name }}
{%- else -%}
{ hdr(host) -i {{ route_domains | join(' ') }} }
{%- endif -%}
{%- if route_prefixes | length > 0 %} { path_beg {{ route_prefixes | join(' ') }} }{%- endif -%}
{%- endmacro %}

{#- Exclude longer matching prefixes so the most-specific route wins. -#}
{%- macro route_more_specific_exclusions(route) -%}
{%- set route_domains = [route.domain] if route.domain is string else route.domain -%}
{%- set route_prefixes = [''] if route.prefix is not defined or route.prefix is none or (route.prefix is string and route.prefix | trim | length == 0) else ([route.prefix | string | trim] if route.prefix is string else (route.prefix | map('string') | map('trim') | list)) -%}
{%- for other_route in haproxy_alb_routes | default([]) -%}
{%- if other_route.name != route.name -%}
{%- set _other_domains = [other_route.domain] if other_route.domain is string else other_route.domain -%}
{%- set _other_prefixes = [''] if other_route.prefix is not defined or other_route.prefix is none or (other_route.prefix is string and other_route.prefix | trim | length == 0) else ([other_route.prefix | string | trim] if other_route.prefix is string else (other_route.prefix | map('string') | map('trim') | list)) -%}
{%- if route_domains | intersect(_other_domains) | list | length > 0 -%}
{%- for route_prefix in route_prefixes -%}
{%- for other_prefix in _other_prefixes -%}
{%- if other_prefix | length > route_prefix | length and (route_prefix | length == 0 or other_prefix.startswith(route_prefix)) %}{{ " " }}!{ path_beg {{ other_prefix }} }{%- endif -%}
{%- endfor -%}
{%- endfor -%}
{%- endif -%}
{%- endif -%}
{%- endfor -%}
{%- endmacro %}

{#- Exclude more-specific throttle prefixes from a broader throttle rule. -#}
{%- macro throttle_more_specific_exclusions(throttle_rule) -%}
{%- set throttle_domains = [throttle_rule.domain] if throttle_rule.domain is string else throttle_rule.domain -%}
{%- set throttle_prefix = throttle_rule.prefix | string | trim -%}
{%- for other_rule in haproxy_alb_throttles | default([]) -%}
{%- set other_domains = [other_rule.domain] if other_rule.domain is string else other_rule.domain -%}
{%- set other_prefix = other_rule.prefix | string | trim -%}
{%- if throttle_domains | intersect(other_domains) | list | length > 0 and other_prefix | length > throttle_prefix | length and other_prefix.startswith(throttle_prefix) %}{{ " " }}!{ path_beg {{ other_prefix }} }{%- endif -%}
{%- endfor -%}
{%- endmacro %}

{#- Add configured exemptions before requiring route Basic Authentication. -#}
{%- macro route_userlist_requirements(route, route_id) -%}
{%- if route.userlist_skip_headers is defined -%}
{%- for hdr_name, hdr_val in route.userlist_skip_headers.items() %}{{ " " }}!{ hdr({{ hdr_name }}) -m str {{ hdr_val }} }{%- endfor -%}
{%- endif -%}
{%- if route.userlist_skip_cidrs is defined -%}
{{ " " }}!{ src -m ip {{ route.userlist_skip_cidrs | join(' ') }} }
{%- endif -%}
{%- if route.userlist_skip_prefixes is defined -%}
{%- for path_prefix in route.userlist_skip_prefixes %}{{ " " }}!{ path_beg {{ path_prefix }} }{%- endfor -%}
{%- endif -%}
{{ " " }}!{ http_auth({{ route.userlist }}) }
{%- if route.userlist_skip_origins is defined %} !{ var(txn.userlist_origin_skip_{{ route_id }}) -m str true }{%- endif -%}
{%- endmacro %}

{#- Track and reject requests that exceed a route throttle limit. -#}
{%- macro throttle_rule_lines(throttle_rule) -%}
{{ "  " }}http-request track-sc0 src table throttle_{{ throttle_rule.name }} if !is_acme {{ route_match(throttle_rule) }}{{ throttle_more_specific_exclusions(throttle_rule) }}
{{ "  " }}http-request deny deny_status {{ haproxy_alb_throttle_deny_status }} if !is_acme {{ route_match(throttle_rule) }}{{ throttle_more_specific_exclusions(throttle_rule) }} { sc_http_req_rate(0,throttle_{{ throttle_rule.name }}) gt {{ throttle_rule.requests }} }
{%- endmacro %}

{#- Require Basic Authentication for a route unless an exemption applies. -#}
{%- macro route_userlist_line(route, route_id) -%}
{{ "  " }}http-request auth realm infra if !is_acme {{ route_match(route) }}{{ route_more_specific_exclusions(route) }}{{ route_userlist_requirements(route, route_id) }}
{%- endmacro %}

{#- Deny requests outside a route's allowed source CIDRs. -#}
{%- macro route_restricted_cidr_deny_line(route) -%}
{{ "  " }}http-request deny deny_status 403 if !is_acme {{ route_match(route) }}{{ route_more_specific_exclusions(route) }} !{ src -m ip {{ route.restricted_cidrs | join(' ') }} }{% if route.restricted_skip_prefixes is defined %}{% for path_prefix in route.restricted_skip_prefixes %} !{ path_beg {{ path_prefix }} }{% endfor %}{% endif %}
{%- endmacro %}

{#- Define origin ACLs that bypass Basic Authentication for embedded resources. -#}
{%- macro route_userlist_origin_acl_lines(route, route_id) %}
{%- set exact_origins = [] -%}
{%- set wildcard_suffixes = [] -%}
{%- for origin in route.userlist_skip_origins -%}
{%- set trimmed_origin = origin | string | trim -%}
{%- if trimmed_origin.startswith('https://*.') -%}
{%- set _ = wildcard_suffixes.append(trimmed_origin | regex_replace('^https://[*][.]', '.')) -%}
{%- else -%}
{%- set _ = exact_origins.append(trimmed_origin) -%}
{%- endif -%}
{%- endfor %}
  acl userlist_origin_iframe_{{ route_id }} req.hdr(Sec-Fetch-Dest) -i iframe
  acl userlist_origin_subresource_{{ route_id }} req.hdr(Sec-Fetch-Site) -i same-origin
  acl userlist_origin_subresource_dest_{{ route_id }} req.hdr(Sec-Fetch-Dest) -i empty script style image font
{% if exact_origins | length > 0 %}
  acl userlist_origin_parent_{{ route_id }} req.hdr(Referer) -m beg {{ exact_origins | map('regex_replace', '$', '/') | join(' ') }}
{% endif %}
{% for wildcard_suffix in wildcard_suffixes %}
  acl userlist_origin_parent_{{ route_id }} req.hdr(Referer) -m reg ^https://[^/][^/]*{{ wildcard_suffix | replace('.', '[.]') }}(/|$)
{% endfor -%}
{%- endmacro %}

{#- Mark requests from approved embedded-resource origins as auth-exempt. -#}
{%- macro route_userlist_origin_skip_lines(route, route_id) -%}
{{ "  " }}http-request set-var(txn.userlist_origin_skip_{{ route_id }}) str(true) if {{ route_match(route) }} userlist_origin_iframe_{{ route_id }} userlist_origin_parent_{{ route_id }}
{{ "  " }}http-request set-var(txn.userlist_origin_skip_{{ route_id }}) str(true) if {{ route_match(route) }} userlist_origin_subresource_{{ route_id }} userlist_origin_subresource_dest_{{ route_id }}
{%- endmacro %}

{#- Render route-specific request header replacements. -#}
{%- macro route_request_header_rewrites(route) -%}
{%- for rewrite in route.request_header_rewrites | default([]) %}
  http-request replace-header {{ rewrite.name }} {{ rewrite.pattern }} {{ rewrite.replacement }} if {{ route_match(route) }}
{% endfor -%}
{%- endmacro %}

{#- Render route-specific response header deletions and replacements. -#}
{%- macro route_response_header_updates(route) -%}
{%- for header_name in route.response_header_deletes | default([]) %}
  http-response del-header {{ header_name }} if { var(txn.route) -m str {{ route.name }} }
{% endfor -%}
{%- for header_name, header_value in (route.response_headers | default({})).items() %}
  http-response set-header {{ header_name }} "{{ header_value }}" if { var(txn.route) -m str {{ route.name }} }
{% endfor -%}
{%- endmacro %}

{#- Collect prefix lengths to emit redirects and route selection most-specific first. -#}
{%- set haproxy_route_prefix_lengths = namespace(values=[]) -%}
{%- for route in haproxy_alb_routes -%}
{%- set route_prefixes = [] if route.prefix is not defined or route.prefix is none or (route.prefix is string and route.prefix | trim | length == 0) else ([route.prefix | string | trim] if route.prefix is string else (route.prefix | map('string') | map('trim') | list)) -%}
{%- for route_prefix in route_prefixes -%}
{%- if route_prefix | length > 0 and route_prefix | length not in haproxy_route_prefix_lengths.values -%}
{%- set haproxy_route_prefix_lengths.values = haproxy_route_prefix_lengths.values + [route_prefix | length] -%}
{%- endif -%}
{%- endfor -%}
{%- endfor -%}
{%- set haproxy_throttle_prefix_lengths = namespace(values=[]) -%}
{%- for throttle_rule in haproxy_alb_throttles | default([]) -%}
{%- set throttle_prefix = throttle_rule.prefix | string | trim -%}
{%- if throttle_prefix | length > 0 and throttle_prefix | length not in haproxy_throttle_prefix_lengths.values -%}
{%- set haproxy_throttle_prefix_lengths.values = haproxy_throttle_prefix_lengths.values + [throttle_prefix | length] -%}
{%- endif -%}
{%- endfor -%}
{#- Strip setup-block whitespace before rendered config. -#}
frontend web
  mode http
  option httplog
  option http-buffer-request
  log global
  log-format "id=%ID ts=%tr host=%{+Q}[var(txn.host)] method=%HM path=%{+Q}HP proto=%HV status=%ST bytes=%B client_ip=%ci client_port=%cp peer_ip=%[var(txn.peer_ip)] frontend=%ft backend=%b server=%s term=%tsc timing=%TR/%Tw/%Tc/%Tr/%Ta conn=%ac/%fc/%bc/%sc/%rc queue=%sq/%bq ssl=%[ssl_fc] sni=%{+Q}[ssl_fc_sni] tls=%{+Q}[ssl_fc_protocol] alpn=%{+Q}[ssl_fc_alpn]"
  bind :80
  bind :443 ssl crt /etc/ssl/haproxy alpn h2,http/1.1
  maxconn 1000
  unique-id-format %[uuid()]
  unique-id-header X-Request-ID
  http-request set-log-level info
  # Request metadata
  http-request set-var(txn.host) req.hdr(host)
  http-request set-var(txn.peer_ip) src
{% if haproxy_alb_crowdsec_enabled | bool %}
  # CrowdSec integration
  filter spoe engine crowdsec config /etc/haproxy/crowdsec.cfg
{% endif %}
{% if haproxy_alb_trusted_proxy_cidrs | default([]) | length > 0 %}
  # Trusted proxy source addresses
  acl from_trusted_proxy src -m ip {{ haproxy_alb_trusted_proxy_cidrs | join(' ') }}
  http-request set-src hdr_ip(X-Forwarded-For,-1) if from_trusted_proxy { hdr_ip(X-Forwarded-For,-1) -m found }
{% endif %}
  # ACME HTTP-01 challenges
  acl is_acme path_beg /.well-known/acme-challenge/
  # Route host ACLs
{% for route in haproxy_alb_routes | sort(attribute='name') %}
{% set route_domains = [route.domain] if route.domain is string else route.domain %}
  acl host_{{ route.name }} hdr(host) -i {{ route_domains | join(' ') }}
{% endfor %}
  # Basic Authentication embedded-resource exemptions
{% for route in haproxy_alb_routes | sort(attribute='name') %}
{% if route.userlist_skip_origins is defined %}{{ route_userlist_origin_acl_lines(route, loop.index0).strip('\n') }}
{% endif %}
{% endfor %}
{% if haproxy_alb_crowdsec_enabled | bool %}
  # CrowdSec request-body inspection
  acl has_request_body req.body_size -m found
  acl body_within_limit req.body_size -m int le {{ haproxy_alb_crowdsec_body_limit }}
{% endif %}
  # Route source-CIDR restrictions
{% for route in haproxy_alb_routes | sort(attribute='name') %}
{% if route.restricted_cidrs is defined %}{{ route_restricted_cidr_deny_line(route) }}
{% endif %}
{% endfor %}
{% if haproxy_alb_crowdsec_enabled | bool %}
  # CrowdSec remediation
  http-request send-spoe-group crowdsec crowdsec-http-body if !is_acme !has_request_body
  http-request send-spoe-group crowdsec crowdsec-http-body if !is_acme has_request_body body_within_limit
  http-request send-spoe-group crowdsec crowdsec-http-no-body if !is_acme has_request_body !body_within_limit
  http-request redirect code 302 location %[url] if { var(txn.crowdsec.remediation) -m str "allow" } { var(txn.crowdsec.redirect) -m found }
  http-request lua.crowdsec_handle if { var(txn.crowdsec.remediation) -m str "captcha" }
  http-request lua.crowdsec_handle if { var(txn.crowdsec.remediation) -m str "ban" }
{% endif %}
{% if haproxy_alb_whitelists_enforced | default([]) | length > 0 %}
  # Enforced source IP allowlists
{% for whitelist_name in haproxy_alb_whitelists_enforced | sort %}
  acl from_whitelist_{{ whitelist_name }} src -m ip -f /opt/haproxy/lists/{{ whitelist_name }}.lst
{% endfor %}
  http-request deny deny_status 403 if !is_acme{% for whitelist_name in haproxy_alb_whitelists_enforced | sort %} !from_whitelist_{{ whitelist_name }}{% endfor %}
{% endif %}
{% if haproxy_alb_redirect_all_http | default(false) | bool %}
  # Global HTTP-to-HTTPS redirect
  http-request redirect scheme https code 301 if !{ ssl_fc } !is_acme
{% endif %}
  # Route-specific HTTP-to-HTTPS redirects, most-specific prefix first
{% for prefix_length in haproxy_route_prefix_lengths.values | sort(reverse=true) %}
{% for route in haproxy_alb_routes | sort(attribute='name') %}
{% set route_prefixes = [] if route.prefix is not defined or route.prefix is none or (route.prefix is string and route.prefix | trim | length == 0) else ([route.prefix | string | trim] if route.prefix is string else (route.prefix | map('string') | map('trim') | list)) %}
{% for route_prefix in route_prefixes | sort %}
{% if not haproxy_alb_redirect_all_http | default(false) | bool and route_prefix | length == prefix_length and (route.proto | default('https')) != 'both' and (route.force_https | default(true)) | bool %}
  http-request redirect scheme https code 301 if !{ ssl_fc } !is_acme {{ route_match(route, [route_prefix]) }}
{% endif %}
{% endfor %}
{% endfor %}
{% endfor %}
{% for route in haproxy_alb_routes | sort(attribute='name') %}
{% set route_prefixes = [] if route.prefix is not defined or route.prefix is none or (route.prefix is string and route.prefix | trim | length == 0) else ([route.prefix | string | trim] if route.prefix is string else (route.prefix | map('string') | map('trim') | list)) %}
{% if not haproxy_alb_redirect_all_http | default(false) | bool and route_prefixes | length == 0 and (route.proto | default('https')) != 'both' and (route.force_https | default(true)) | bool %}
  http-request redirect scheme https code 301 if !{ ssl_fc } !is_acme {{ route_match(route) }}
{% endif %}
{% endfor %}
  # Select the route used for response-header policies, most-specific prefix first
{% for prefix_length in haproxy_route_prefix_lengths.values | sort(reverse=true) %}
{% for route in haproxy_alb_routes | sort(attribute='name') %}
{% set route_prefixes = [] if route.prefix is not defined or route.prefix is none or (route.prefix is string and route.prefix | trim | length == 0) else ([route.prefix | string | trim] if route.prefix is string else (route.prefix | map('string') | map('trim') | list)) %}
{% for route_prefix in route_prefixes | sort %}
{% if route_prefix | length == prefix_length %}
  http-request set-var(txn.route) str({{ route.name }}) if !{ var(txn.route) -m found } {{ route_match(route, [route_prefix]) }}
{% endif %}
{% endfor %}
{% endfor %}
{% endfor %}
  # Basic Authentication origin exemptions
{% for route in haproxy_alb_routes | sort(attribute='name') %}
{% set route_prefixes = [] if route.prefix is not defined or route.prefix is none or (route.prefix is string and route.prefix | trim | length == 0) else ([route.prefix | string | trim] if route.prefix is string else (route.prefix | map('string') | map('trim') | list)) %}
{% if route_prefixes | length == 0 %}
  http-request set-var(txn.route) str({{ route.name }}) if !{ var(txn.route) -m found } {{ route_match(route) }}
{% endif %}
{% endfor %}
{% for route in haproxy_alb_routes | sort(attribute='name') %}
{% if route.userlist_skip_origins is defined %}{{ route_userlist_origin_skip_lines(route, loop.index0).strip('\n') }}
{% endif %}
{% endfor %}
  # Per-route request throttling, most-specific prefix first
{% for prefix_length in haproxy_throttle_prefix_lengths.values | sort(reverse=true) %}
{% for throttle_rule in haproxy_alb_throttles | default([]) %}
{% set throttle_prefix = throttle_rule.prefix | string | trim %}
{% if throttle_prefix | length == prefix_length %}
{{ throttle_rule_lines(throttle_rule) }}
{% endif %}
{% endfor %}
{% endfor %}
  # Per-route Basic Authentication
{% for route in haproxy_alb_routes | sort(attribute='name') %}
{% if route.userlist is defined %}
{{ route_userlist_line(route, loop.index0) }}
{% endif %}
{% endfor %}

  # Forwarded request headers
  http-request set-header X-Forwarded-For %[src]
  http-request set-header X-Forwarded-Host %[req.hdr(host)]
  http-request set-header X-Forwarded-Proto https if { ssl_fc }
  # Route-specific request header rewrites
{% for route in haproxy_alb_routes | sort(attribute='name') %}{% if route.request_header_rewrites is defined %}{{ route_request_header_rewrites(route).strip('\n') }}
{% endif %}{% endfor %}
  # Load balancer identification header
  http-response set-header X-ALB %[hostname]
  # Route-specific response header updates
{% for route in haproxy_alb_routes | sort(attribute='name') %}{% if route.response_header_deletes is defined or route.response_headers is defined %}{{ route_response_header_updates(route).strip('\n') }}
{% endif %}{% endfor %}
{% if haproxy_alb_crowdsec_enabled | bool %}
  # CrowdSec CAPTCHA cookie propagation
  http-after-response set-header Set-Cookie %[var(txn.crowdsec.captcha_cookie)] if { var(txn.crowdsec.captcha_status) -m found } { var(txn.crowdsec.captcha_cookie) -m found }
  http-after-response set-header Set-Cookie %[var(txn.crowdsec.captcha_cookie)] if { var(txn.crowdsec.captcha_cookie) -m found } !{ var(txn.crowdsec.captcha_status) -m found }
{% endif %}
{% if haproxy_alb_acme_enabled | bool %}
