listen bypass_{{ item.name }}
  mode tcp
  option tcplog
  bind :{{ item.bind }}
  server {{ item.name }} {{ item.host }}:{{ item.port }} init-addr libc,none fall 2 rise 1
  timeout server {{ item.server_timeout | default(haproxy_bypass_default_server_timeout) }}
  timeout client {{ item.client_timeout | default(haproxy_bypass_default_client_timeout) }}
