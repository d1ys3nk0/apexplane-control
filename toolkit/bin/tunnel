#!/usr/bin/env bash

set -euo pipefail

load_env_files() {
    local env_file

    for env_file in .env .env.local; do
        if [ -f "${env_file}" ]; then
            set -a
            # shellcheck disable=SC1090
            . "${env_file}"
            set +a
        fi
    done
}

load_env_files

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec uv run python "${SCRIPT_DIR}/../scripts/tunnel.py" "$@"
