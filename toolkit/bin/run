#!/usr/bin/env bash

set -euo pipefail

cmd() {
    printf '> '
    printf '%q ' "$@"
    printf '\n'

    "$@"
}

cmd_capture() {
    printf '> ' >&2
    printf '%q ' "$@" >&2
    printf '\n' >&2

    "$@"
}

TARGET_REALM="${1:-}"
TARGET_PLATFORM="${2:-}"
TARGET_CLUSTER="${3:-}"
TARGET_ACTION="${4:-}"
TARGET_ARGS=("${@:5}")

for VAR in TARGET_REALM TARGET_PLATFORM TARGET_CLUSTER TARGET_ACTION; do
    VAR_VALUE=$(eval echo \$$VAR)
    if [ -z "$VAR_VALUE" ]; then
        echo "Error: $VAR is not set"
        exit 1
    fi
done

LOG_DIR="log"
CHANGED_LOG_PATH="${LOG_DIR}/${TARGET_REALM}-${TARGET_CLUSTER}-${TARGET_ACTION}.log"
RUN_LOG_PATH=""
LOG_STARTED=0
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLKIT_RUNTIME_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
REMOTE_STATE_SCRIPT="${TOOLKIT_RUNTIME_DIR}/scripts/remote_ansible_state.py"
REMOTE_STATE_NAMESPACE="${REMOTE_STATE_NAMESPACE:-ansible-$(basename "${PWD}")}"
REMOTE_LOCK_ACQUIRED=0
REMOTE_LOCKED_BY=""
export ANSIBLE_FORCE_COLOR="${ANSIBLE_FORCE_COLOR:-1}"

timestamped_log_path() {
    local prefix="$1"
    local path

    while true; do
        path="${LOG_DIR}/${prefix}$(date -u +%y%m%d%H%M%S).log"
        if (set -C; : >"${path}") 2>/dev/null; then
            printf '%s\n' "${path}"
            return 0
        fi
        sleep 1
    done
}

cleanup() {
    local status=$?
    local changed_log_extract_path

    if [ "${REMOTE_LOCK_ACQUIRED}" = "1" ]; then
        remote_state release --locked-by "${REMOTE_LOCKED_BY}" >/dev/null || true
    fi

    if [ "${LOG_STARTED}" != "1" ]; then
        exit "${status}"
    fi

    changed_log_extract_path="$(timestamped_log_path ".${TARGET_REALM}-${TARGET_CLUSTER}-${TARGET_ACTION}-changed-")"
    if grep -F 'changed:' "${RUN_LOG_PATH}" >"${changed_log_extract_path}"; then
        cat "${changed_log_extract_path}" >>"${CHANGED_LOG_PATH}"
        if [ -n "${DRIFT_FAIL_ON_CHANGE:-}" ]; then
            printf '\n[DRIFT] Changes detected in %s/%s/%s:\n' "${TARGET_REALM}" "${TARGET_CLUSTER}" "${TARGET_ACTION}" >&2
            cat "${changed_log_extract_path}" >&2
            rm -f "${changed_log_extract_path}" "${RUN_LOG_PATH}"
            exit 2
        fi
    fi
    rm -f "${changed_log_extract_path}" "${RUN_LOG_PATH}"

    exit "${status}"
}

trap cleanup EXIT

start_run_log() {
    mkdir -p "${LOG_DIR}"
    RUN_LOG_PATH="$(timestamped_log_path ".${TARGET_REALM}-${TARGET_CLUSTER}-${TARGET_ACTION}-run-")"
    LOG_STARTED=1
    export ANSIBLE_LOG_PATH="${RUN_LOG_PATH}"
}

load_env_files() {
    local env_file
    local env_entry
    local env_name
    local index
    local preserved_env_names=()
    local preserved_env_values=()
    local status

    for env_file in .env .env.local; do
        if [ -f "${env_file}" ]; then
            echo "Loading ${env_file}..."
            preserved_env_names=()
            preserved_env_values=()
            while IFS= read -r -d '' env_entry; do
                env_name="${env_entry%%=*}"
                if [[ "${env_name}" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
                    preserved_env_names+=("${env_name}")
                    preserved_env_values+=("${env_entry#*=}")
                fi
            done < <(env -0)
            set -a
            # shellcheck disable=SC1090
            if ! . "${env_file}"; then
                status=$?
                set +a
                for index in "${!preserved_env_names[@]}"; do
                    printf -v "${preserved_env_names[index]}" '%s' "${preserved_env_values[index]}"
                    export "${preserved_env_names[index]}"
                done
                return "${status}"
            fi
            set +a
            for index in "${!preserved_env_names[@]}"; do
                printf -v "${preserved_env_names[index]}" '%s' "${preserved_env_values[index]}"
                export "${preserved_env_names[index]}"
            done
        fi
    done
}

load_env_files

if [ "${TARGET_PLATFORM}" == "all" ]; then
    echo "Specify platform"
    exit 1
fi

if [ "${TARGET_ACTION}" != "cmd" ]; then
    PLAYBOOK_PATH="playbooks/${TARGET_CLUSTER}/${TARGET_ACTION}.yml"

    if [ ! -f "${PLAYBOOK_PATH}" ]; then
        echo "Playbook file ${PLAYBOOK_PATH} is not found for action ${TARGET_ACTION} in cluster ${TARGET_CLUSTER}"
        exit 1
    fi
fi

VAR_FILES=(
    "variables/_global.yml"
    "variables/_shared.yml"
    "variables/${TARGET_CLUSTER}/_global.yml"
    "variables/${TARGET_CLUSTER}.yml"
    "variables/${TARGET_REALM}/_vault.yml"
    "variables/${TARGET_REALM}/_global.yml"
    "variables/${TARGET_REALM}/_shared.yml"
    "variables/${TARGET_REALM}/${TARGET_CLUSTER}/_global.yml"
    "variables/${TARGET_REALM}/${TARGET_CLUSTER}.yml"
    "variables/${TARGET_REALM}_${TARGET_PLATFORM}/_vault.yml"
    "variables/${TARGET_REALM}_${TARGET_PLATFORM}/_global.yml"
    "variables/${TARGET_REALM}_${TARGET_PLATFORM}/_shared.yml"
    "variables/${TARGET_REALM}_${TARGET_PLATFORM}/${TARGET_CLUSTER}/_global.yml"
    "variables/${TARGET_REALM}_${TARGET_PLATFORM}/${TARGET_CLUSTER}.yml"
)

if [ -n "${TGT:-}" ]; then
    TARGET_HOSTS="${TGT}"
else
    TARGET_HOSTS="${TARGET_REALM}_${TARGET_PLATFORM}_${TARGET_CLUSTER}"
fi

VARIABLES_DIR="variables/${TARGET_REALM}"
if [ ! -d "${VARIABLES_DIR}" ]; then
    echo "Variables directory ${VARIABLES_DIR} is not found for realm ${TARGET_REALM}"
    exit 1
fi

INVENTORY_PATH="inventories/${TARGET_CLUSTER}/${TARGET_REALM}.yml"
if [ ! -f "${INVENTORY_PATH}" ]; then
    echo "Inventory file ${INVENTORY_PATH} is not found for cluster ${TARGET_CLUSTER} in realm ${TARGET_REALM}"
    exit 1
fi

EXTRA_VARS_ARRAY=()

validate_extra_vars_file() {
    local var_file="$1"

    if head -n 1 "${var_file}" | grep -q '^[$]ANSIBLE_VAULT;'; then
        return 0
    fi

    uv run python - "${var_file}" <<'PY'
import sys
from pathlib import Path

import yaml

path = Path(sys.argv[1])
try:
    value = yaml.safe_load(path.read_text(encoding="utf-8"))
except yaml.YAMLError as exc:
    raise SystemExit(f"Extra vars file {path} is not valid YAML: {exc}") from exc

if not isinstance(value, dict):
    raise SystemExit(f"Extra vars file {path} must contain a YAML mapping")
PY
}

for VAR_FILE in "${VAR_FILES[@]}"; do
    if [ -f "${VAR_FILE}" ]; then
        validate_extra_vars_file "${VAR_FILE}"
        echo "Using ${VAR_FILE}"
        EXTRA_VARS_ARRAY+=("-e" "@${VAR_FILE}")
    fi
done
EXTRA_VARS_ARRAY+=("-e" "cluster_realm=${TARGET_REALM}" "-e" "cluster_name=${TARGET_CLUSTER}" "-e" "target_hosts=${TARGET_HOSTS}")
: "${ANSIBLE_SSH_USER:?Error: ANSIBLE_SSH_USER is not set}"
SSH_ARGS=()
if [ -n "${ANSIBLE_SSH_KEY_PATH:-}" ]; then
    SSH_ARGS+=(--private-key "${ANSIBLE_SSH_KEY_PATH}")
fi

is_read_only_action() {
    [[ "${TARGET_ACTION}" == "assess" ]]
}

is_live_action() {
    [[ "${DRY:-1}" =~ ^(0|false)$ ]]
}

remote_state() {
    local action="$1"
    local remote_args
    shift

    printf -v remote_args '%q ' "${REMOTE_STATE_SCRIPT}" --namespace "${REMOTE_STATE_NAMESPACE}" "${action}" "$@"
    cmd_capture uv run ansible "${TARGET_HOSTS}" -i "${INVENTORY_PATH}" "${EXTRA_VARS_ARRAY[@]}" -u "${ANSIBLE_SSH_USER}" ${SSH_ARGS+"${SSH_ARGS[@]}"} -b \
        -m ansible.builtin.script -a "${remote_args% }"
}

acquire_remote_lock() {
    local lock_output

    if ! is_live_action; then
        return 0
    fi

    REMOTE_LOCKED_BY="$(id -un)@$(hostname -s):pid=$$:task apc:run:${TARGET_REALM}/${TARGET_PLATFORM}/${TARGET_CLUSTER}/${TARGET_ACTION}"
    if [[ "${UNLOCK:-0}" =~ ^(1|true)$ ]]; then
        remote_state unlock >/dev/null
    fi
    if ! lock_output="$(remote_state acquire --locked-by "${REMOTE_LOCKED_BY}" 2>&1)"; then
        printf '%s\n' "${lock_output}"
        echo "Failed to acquire remote Ansible lock"
        return 1
    fi
    REMOTE_LOCK_ACQUIRED=1
}

if [ "${TARGET_ACTION}" = "cmd" ]; then
    if [ "${#TARGET_ARGS[@]}" -eq 0 ]; then
        echo "Error: Command is required when using 'cmd' action"
        exit 1
    fi

    start_run_log
    if is_live_action; then
        acquire_remote_lock
    fi

    cmd uv run ansible "${TARGET_HOSTS}" -i "${INVENTORY_PATH}" "${EXTRA_VARS_ARRAY[@]}" -m shell -u "${ANSIBLE_SSH_USER}" ${SSH_ARGS+"${SSH_ARGS[@]}"} -a "${TARGET_ARGS[*]}"
else
    CMD=(uv run ansible-playbook "${PLAYBOOK_PATH}" -i "${INVENTORY_PATH}" "${EXTRA_VARS_ARRAY[@]}" -u "${ANSIBLE_SSH_USER}" ${SSH_ARGS+"${SSH_ARGS[@]}"} --limit "${TARGET_HOSTS}")

    if [[ ! "${CI:-0}" =~ ^(1|true)$ ]] || [[ "${DEBUG:-}" =~ ^(1|true)$ ]] || [[ -n "${DRIFT_FAIL_ON_CHANGE:-}" ]]; then
        CMD+=(--diff -v)
    fi

    if [ -n "${T:-}" ]; then
        CMD+=(-t "${T}")
    fi

    if [ -n "${S:-}" ]; then
        CMD+=(--skip-tags "${S}")
    fi

    RUN_CMD=("${CMD[@]}")

    echo "> Running syntax check..."
    cmd "${CMD[@]}" --syntax-check

    if ! is_read_only_action && ! is_live_action; then
        RUN_CMD+=(--check)
    fi

    if [ "${#TARGET_ARGS[@]}" -gt 0 ]; then
        RUN_CMD+=("${TARGET_ARGS[@]}")
    fi

    echo "> Running playbook..."
    start_run_log
    if is_live_action; then
        acquire_remote_lock
    fi
    cmd "${RUN_CMD[@]}"
fi
